            "command": "{{PYTHON_CMD}} -B {{CODEX_HOOKS_DIR}}/session-start-context.py",
            "statusMessage": "Loading session mode context",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
